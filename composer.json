{
    "name": "xingen/xingen-sdk",
    "description": "PHP client SDK for the Xingen e-invoice validation API",
    "type": "library",
    "license": "MIT",
    "keywords": ["xingen", "e-invoice", "invoice", "en16931", "xrechnung", "peppol", "ubl", "cii"],
    "homepage": "https://github.com/nko-technologies/xingen-php-sdk",
    "authors": [
        {
            "name": "Manuel Gerstner",
            "email": "manuel@nko-technologies.com"
        }
    ],
    "require": {
        "php": ">=8.1",
        "ext-curl": "*",
        "ext-json": "*"
    },
    "require-dev": {
        "phpunit/phpunit": "^10.5"
    },
    "autoload": {
        "psr-4": {
            "Xingen\\Sdk\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Xingen\\Sdk\\Tests\\": "tests/"
        }
    },
    "scripts": {
        "test": "phpunit"
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}
